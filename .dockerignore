# ── Version control ───────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Python cache ──────────────────────────────────────────────────────────
__pycache__
*.py[cod]
*$py.class
*.pyo
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov/
dist/
build/
*.egg-info/
*.egg

# ── Virtual environments ─────────────────────────────────────────────────
.venv
venv
env
ENV

# ── IDE / editor ──────────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker files themselves (no need to COPY into image) ─────────────────
Dockerfile*
docker-compose*.yml
.dockerignore

# ── Docs and non-runtime assets ──────────────────────────────────────────
README.md
LICENSE
*.md
docs/

# ── Test files ────────────────────────────────────────────────────────────
tests/
test_*
*_test.py

# ── Local config and secrets (mount as volume instead) ───────────────────
.env
.env.*
*.local
config.json
secrets/

# ── Windows installer / batch shortcuts ──────────────────────────────────
install.ps1
ai.bat
vivian.bat

# ── Large binary / data files ────────────────────────────────────────────
*.sqlite
*.db
*.log
*.zip
*.tar.gz
